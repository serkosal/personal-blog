# security
DEBUG=1                             # Use django debug mode
LOCALHOST_ALLOWED=1                 # Adds localhost into allowed hosts django
SECRET_KEY='django-secret-key'

# frontend config
# Runs vite dev server and refreshes page in browser on .js, .css updates
# including both front and backend (includes django template) 
FRONTEND_HMR=1

# email
EMAIL_HOST='mail.example.com' # from mx DNS record
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_TIMEOUT=30
EMAIL_HOST_USER='admin@example.com'
EMAIL_HOST_PASSWORD='examplePassword'


# database configuration
USE_SQLITE=1                        # Use sqlite database
POSTGRES_DB="site"
POSTGRES_USER="postgres-user"
POSTGRES_PASSWORD='postgres-pass'
POSTGRES_HOST="db"
POSTGRES_PORT='5432'


# rabitmq configuration
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
